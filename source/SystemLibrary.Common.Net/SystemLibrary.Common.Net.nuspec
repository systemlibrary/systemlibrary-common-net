<?xml version = "1.0" ?>
<package xmlns="http://schemas.microsoft.com/packaging/2010/07/nuspec.xsd">
	<metadata>
		<id>SystemLibrary.Common.Net</id>

		<version>2.0.1.4</version>

		<authors>System Library</authors>

		<owners>System Library</owners>

		<projectUrl>https://systemlibrary.com/package/SystemLibrary.Common.Net</projectUrl>

		<license type="expression">Apache-2.0</license>

		<icon>nuget-icon.png</icon>

		<requireLicenseAcceptance>false</requireLicenseAcceptance>

		<releaseNotes>
			Latest version:
			https://github.com/systemlibrary/systemlibrary-common-net#latest-version

			Documentation:
			https://systemlibrary.github.io/systemlibrary-common-net/
		</releaseNotes>
		
		<description>
			A library of classes and methods for any .NET >= 5 application

			Selling points:
			- Common extension on strings, enums, arrays...
			- Create your own json file and inherit Config&lt;&gt; class and your json is auto-read into the C# class
			- Simple "console.log" through Dump.Write()
			- Simple extension method on object and string named 'ToJson()'
			- Simple "Fire and Forget" through Async.Run()

			Documentation:
			https://systemlibrary.github.io/systemlibrary-common-net/

			Source code:
			https://github.com/systemlibrary/systemlibrary-common-net
		</description>

		<copyright>Copyright © System Library</copyright>

		<tags>C# .NET 5.0 Config Extensions</tags>

		<dependencies>
			<dependency id="Microsoft.Extensions.Configuration.Binder" version="6" />
			<dependency id="Microsoft.Extensions.Configuration.EnvironmentVariables" version="6" />
			<dependency id="Microsoft.Extensions.Configuration.Json" version="6" />
			<dependency id="Microsoft.Extensions.Configuration.Xml" version="6" />
		</dependencies>
	</metadata>

	<files>
		<file src="nuget-icon.png" target="" />
	</files>
</package>
<!-- Command: nuget pack SystemLibrary.Common.Net.csproj -p Configuration=Release -->